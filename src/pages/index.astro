---
import BaseLayout from "../layouts/BaseLayout.astro";

const modules = [
  { num: "01", tag: "EXPLORER",     title: "Repository Intelligence",        desc: "Category browsing and free search with tactical insights on each repo.", href: "/explorer" },
  { num: "02", tag: "TITANS",       title: "Big Tech Stack Mapping",          desc: "Curated repo sets by company. Compare strategic AI directions at a glance.", href: "/titans" },
  { num: "03", tag: "MCP",          title: "MCP Registry Layer",              desc: "Search official MCP servers and inspect protocol metadata.", href: "/mcp" },
  { num: "04", tag: "DOCS",         title: "Source-of-Truth Documentation",   desc: "Direct access to official docs for models, APIs, and frameworks.", href: "/docs" },
  { num: "05", tag: "CODE REVIEW",  title: "GitHub Review Workflow",          desc: "AI-powered review across refactor, docs, efficiency and security.", href: "/code-review" },
];
---

<BaseLayout title="AI THINGS" description="AI things: esplora il mondo AI in costante evoluzione.">

  <!-- HERO: 2-column layout -->
  <section id="section-hero" class="home-hero-block animate-entry">
    <div class="home-hero-grid">

      <div class="home-hero-left">
        <p class="home-hero-kicker" data-i18n="home_kicker">AI THINGS / MISSION</p>
        <h2 class="home-hero-title" data-i18n="home_title">
          Your map in the<br />constantly evolving<br />AI world.
        </h2>
        <p class="home-hero-desc" data-i18n="home_desc">
          A single destination to explore tools, models, protocols and documentation without noise.
          From discovery to implementation — always the right context.
        </p>
        <div class="home-hero-actions">
          <a href="#section-modules" class="home-cta home-cta--primary" data-i18n="home_cta_explore">Start exploring</a>
          <a href="/explorer" class="home-cta">Open Explorer</a>
        </div>
      </div>

      <aside class="home-highlights-panel" aria-label="What you find here">
        <p class="home-highlights-label" data-i18n="home_highlights_label">WHAT YOU FIND HERE</p>
        <ul class="home-highlights-list">
          <li class="home-highlight-item">
            <span class="home-highlight-num">01</span>
            <span data-i18n="home_hl_1">Curated AI repos with tactical insight</span>
          </li>
          <li class="home-highlight-item">
            <span class="home-highlight-num">02</span>
            <span data-i18n="home_hl_2">Big-tech AI stacks mapped by player</span>
          </li>
          <li class="home-highlight-item">
            <span class="home-highlight-num">03</span>
            <span data-i18n="home_hl_3">Official MCP servers &amp; protocol registry</span>
          </li>
          <li class="home-highlight-item">
            <span class="home-highlight-num">04</span>
            <span data-i18n="home_hl_4">Source-of-truth docs &amp; code quality review</span>
          </li>
        </ul>
      </aside>

    </div>
  </section>

  <!-- MODULE CARDS — each row is a full clickable link -->
  <div class="home-modules" id="section-modules">
    {modules.map((m) => (
      <a href={m.href} class="home-module-card">
        <span class="home-module-kicker"><span class="home-module-num">{m.num}</span> / {m.tag}</span>
        <span class="home-module-title">{m.title}</span>
        <span class="home-module-desc">{m.desc}</span>
        <span class="home-module-arrow">→</span>
      </a>
    ))}
  </div>

</BaseLayout>
